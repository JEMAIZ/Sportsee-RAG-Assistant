# ============================================================
# SPORTSEE — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# NE JAMAIS committer le fichier .env reel !
# ============================================================

# --- Mistral API ---
MISTRAL_API_KEY=your_mistral_api_key_here

# --- Modeles Mistral ---
MODEL_NAME=mistral-small-latest
EMBEDDING_MODEL=mistral-embed

# --- Application ---
APP_TITLE=SportSee NBA Analyst AI
NAME=NBA Regular Season

# --- RAG ---
SEARCH_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Chemins ---
INPUT_DIR=inputs
VECTOR_DB_DIR=vector_db
DB_PATH=database/sportsee.db
